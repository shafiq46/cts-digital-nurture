<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Local Community Event Portal</title>
<style>
body{
font-family:Arial,sans-serif;
margin:20px;
background:#f4f4f4;
}
#welcomeBanner{
background:blue;
color:white;
padding:15px;
text-align:center;
}
.highlight{
background:yellow;
font-weight:bold;
}
img.gallery{
width:200px;
height:150px;
border:2px solid black;
}
table{
margin:auto;
}
form{
background:white;
padding:20px;
border-radius:10px;
width:50%;
}
input,select,textarea{
width:100%;
padding:8px;
margin:5px 0;
}
button{
padding:10px;
margin-top:10px;
}
</style>
<script>
function validatePhone(){
let phone=document.getElementById("phone").value;
if(phone.length!=10){
alert("Enter Valid Phone Number");
}
}
function showFee(){
let fee=document.getElementById("eventType").value;
document.getElementById("fee").innerHTML=
"Fee : ₹"+fee;
}
function submitForm(){
document.getElementById("confirm").innerHTML=
"Registration Successful";
}
function enlarge(img){
img.style.width="300px";
img.style.height="250px";
}
function countChars(){
let len=document.getElementById("feedback").value.length;
document.getElementById("count").innerHTML=
"Characters : "+len;
}
function videoReady(){
document.getElementById("videoMsg").innerHTML=
"Video Ready To Play";
}
window.onbeforeunload=function(){
return "Form not completed. Leave page?";
}
function savePreference(){
let val=document.getElementById("eventType").value;
localStorage.setItem("event",val);
}
function loadPreference(){
let saved=localStorage.getItem("event");
if(saved){
document.getElementById("eventType").value=saved;
}
}
function clearPreference(){
localStorage.clear();
sessionStorage.clear();
alert("Preferences Cleared");
}
function findLocation(){
navigator.geolocation.getCurrentPosition(
function(pos){
document.getElementById("location").innerHTML=
"Latitude : "+pos.coords.latitude+
"<br>Longitude : "+pos.coords.longitude;
},
function(error){
alert("Location Access Denied");
},

{
enableHighAccuracy:true,
timeout:5000
}

);

}
</script>
</head>
<body onload="loadPreference()">
<nav>
<a href="#home">Home</a> |
<a href="#events">Events</a> |
<a href="#contact">Contact</a> |
<a href="help.html" target="_blank">Help</a>
</nav>

<br>

<div id="welcomeBanner">

<h1>Welcome to Community Event Portal</h1>

<p>
Special Offer :
<span style="color:red;font-weight:bold;">
50% Discount
</span>
</p>

</div>

<br>

<section id="home">
<h2 class="highlight">Home Section</h2>
</section>
<section id="events">

<h2>Event Gallery</h2>
<table>
<tr>
<td>
<img src="event1.jpg" class="gallery"
alt="Music Event"
title="Music Event"
ondblclick="enlarge(this)">
<br>Music Event
</td>
<td>
<img src="event2.jpg" class="gallery"
alt="Food Festival"
title="Food Festival"
ondblclick="enlarge(this)">
<br>Food Festival
</td>
<td>
<img src="event3.jpg" class="gallery"
alt="Sports Meet"
title="Sports Meet"
ondblclick="enlarge(this)">
<br>Sports Meet
</td>

</tr>

<tr>

<td>
<img src="event4.jpg" class="gallery"
alt="Dance Show"
title="Dance Show">
<br>Dance Show
</td>

<td>
<img src="event5.jpg" class="gallery"
alt="Art Expo"
title="Art Expo">
<br>Art Expo
</td>

<td>
<img src="event6.jpg" class="gallery"
alt="Book Fair"
title="Book Fair">
<br>Book Fair
</td>

</tr>

</table>

</section>

<br>



<h2>Event Registration</h2>

<form>

Name:
<input type="text"
placeholder="Enter Name"
required autofocus>

Email:
<input type="email"
placeholder="Enter Email"
required>

Phone:
<input type="text"
id="phone"
onblur="validatePhone()">

Date:
<input type="date" required>

Event Type:

<select id="eventType"
onchange="showFee();savePreference();">

<option value="100">Music Event</option>
<option value="200">Food Festival</option>
<option value="300">Sports Meet</option>

</select>

<p id="fee"></p>

Message:

<textarea rows="4"></textarea>

Feedback:

<textarea id="feedback"
onkeyup="countChars()"></textarea>

<p id="count"></p>

<button type="button"
onclick="submitForm()">
Register
</button>

<output id="confirm"></output>

</form>

<br>


<h2>Event Promo Video</h2>

<video width="400"
controls
oncanplay="videoReady()">

<source src="promo.mp4"
type="video/mp4">

</video>

<p id="videoMsg"></p>

<br>

<button onclick="clearPreference()">
Clear Preferences
</button>

<br><br>

<button onclick="findLocation()">
Find Nearby Events
</button>
<p id="location"></p>
<section id="contact">
<h2>Contact Us</h2>
<p>Email : events@community.com</p>
</section>

</body>
</html>
